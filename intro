    setNotificacion({ mensaje, tipo });
    setTimeout(() => setNotificacion(null), 4000);
  };

  // --- Función Auxiliar para Auditoría ---
  const agregarLog = (accion) => {
    const ahora = new Date();
    const horaFormateada = ahora.toLocaleTimeString([], { hour: '2-digit', minute: '2-digit' });
    setLogs(prev => [{ hora: horaFormateada, accion }, ...prev]);
  };

  // --- Filtrado Inteligente de Libros (Estudiante) ---
  const librosFiltrados = useMemo(() => {
    const inicio = performance.now();
    const resultado = libros.filter(libro => {
      // Coincidencia con barra de búsqueda única
      const matchesSearch = busquedaAplicada === '' || 
        libro.titulo.toLowerCase().includes(busquedaAplicada.toLowerCase()) ||
        libro.autor.toLowerCase().includes(busquedaAplicada.toLowerCase()) ||
        libro.isbn.includes(busquedaAplicada);

      // Coincidencia con filtros de categorías
      const algunaCategoriaActiva = filtros.Ingenieria || filtros.Literatura || filtros.Ciencias;
      let matchesCategoria = true;
      if (algunaCategoriaActiva) {
        matchesCategoria = 
          (filtros.Ingenieria && libro.categoria === 'Ingeniería') ||
          (filtros.Literatura && libro.categoria === 'Literatura') ||
          (filtros.Ciencias && libro.categoria === 'Ciencias');
      }

      // Filtro de sólo disponibles (stock mayor a cero)
      const matchesDisponible = !filtros.Disponible || libro.stock > 0;

      return matchesSearch && matchesCategoria && matchesDisponible;
    });

    const fin = performance.now();
    // Simular un tiempo realista basado en la carga (entre 0.01s y 1.5s ficticio para calzar con el mockup)
    setTiempoBusqueda(parseFloat(((fin - inicio) / 1000 + 0.04).toFixed(2)));
    return resultado;
  }, [libros, busquedaAplicada, filtros]);

  // --- Préstamos filtrados para el estudiante en sesión (Juan Pérez) ---
  const prestamosEstudianteActivo = useMemo(() => {
    return prestamos.filter(p => p.estudianteCedula === "0912345678");
  }, [prestamos]);

  // --- Acciones del Estudiante ---
  const handleBuscarEstudiante = (e) => {
    e.preventDefault();
    setBusquedaAplicada(busqueda);
    mostrarNotificacion(`Catálogo actualizado para: "${busqueda || 'Todos los libros'}"`, 'info');
  };

  const toggleFiltro = (filtroKey) => {
    setFiltros(prev => ({ ...prev, [filtroKey]: !prev[filtroKey] }));
  };

  const solicitarPrestamoEstudiante = (libro) => {
    if (libro.stock <= 0) {
      mostrarNotificacion(`El libro "${libro.titulo}" no cuenta con copias disponibles.`, 'error');
      return;
    }

    // Comprobar si el estudiante ya tiene este libro prestado
    const yaPrestado = prestamos.some(p => p.estudianteCedula === "0912345678" && p.titulo === libro.titulo);
    if (yaPrestado) {
      mostrarNotificacion(`Ya tienes un préstamo activo o pendiente para "${libro.titulo}".`, 'info');
      return;
    }

    // Actualizar stock del libro
    setLibros(prev => prev.map(l => {
      if (l.id === libro.id) {
        return { ...l, stock: l.stock - 1 };
      }
      return l;
    }));

    // Registrar préstamo
    const hoy = new Date();
    hoy.setDate(hoy.getDate() + 15);
    const fechaVencimiento = hoy.toISOString().split('T')[0];

    const nuevoP = {
      id: Date.now(),
      estudianteCedula: "0912345678",
      libroIsbn: libro.isbn,
      titulo: libro.titulo,
      fechaVencimiento,
      estado: "Al día"
    };

    setPrestamos(prev => [nuevoP, ...prev]);
    mostrarNotificacion(`¡Préstamo de "${libro.titulo}" solicitado! Acércate al módulo con tu ID.`, 'exito');
    agregarLog(`Juan Pérez Solís solicitó en línea: "${libro.titulo}" (Stock restante: ${libro.stock - 1})`);
  };

  const devolverPrestamoEstudiante = (id, titulo) => {
    // Eliminar del array de préstamos
    setPrestamos(prev => prev.filter(p => p.id !== id));
    
    // Regresar stock
    setLibros(prev => prev.map(l => {
      if (l.titulo === titulo) {
        return { ...l, stock: l.stock + 1 };
      }
      return l;
    }));

    mostrarNotificacion(`Has devuelto "${titulo}" virtualmente. Entrega el físico en ventanilla.`, 'exito');
    agregarLog(`Juan Pérez Solís devolvió: "${titulo}"`);
  };

  const renovarPrestamoEstudiante = (id, titulo) => {
    setPrestamos(prev => prev.map(p => {
      if (p.id === id) {
        const f = new Date(p.fechaVencimiento);
        f.setDate(f.getDate() + 7);
        return { ...p, fechaVencimiento: f.toISOString().split('T')[0], estado: "Al día" };
      }
      return p;
    }));
    mostrarNotificacion(`Plazo del libro "${titulo}" extendido por 7 días.`, 'info');
    agregarLog(`Se renovó plazo para: "${titulo}" por el estudiante Juan Pérez.`);
  };


  // --- Acciones de Administración (Bibliotecario) ---

  // 1. Validar Estudiante (Paso 1 del Registro de Préstamo)
  const handleValidarEstudianteAdmin = () => {
    const est = estudiantes.find(e => e.cedula === idEstudianteInput);
    if (est) {
      if (est.estado === 'Inactivo') {
        mostrarNotificacion(`Estudiante bloqueado o inactivo por mora académica.`, 'error');
        setEstudianteValidado(null);
      } else {
        setEstudianteValidado(est);
        mostrarNotificacion(`Estudiante verificado: ${est.nombre}`, 'exito');
      }
    } else {
      mostrarNotificacion(`Identificación no registrada en el sistema de matrículas.`, 'error');
      setEstudianteValidado(null);
    }
  };

  // 2. Validar Libro (Paso 2 del Registro de Préstamo)
  const handleValidarLibroAdmin = () => {
    const lib = libros.find(l => l.isbn === isbnInput);
    if (lib) {
      if (lib.stock <= 0) {
        mostrarNotificacion(`No hay stock físico de "${lib.titulo}".`, 'error');
        setLibroValidado(null);
      } else {
        setLibroValidado(lib);
        mostrarNotificacion(`Libro verificado: ${lib.titulo} (Copias: ${lib.stock})`, 'exito');
      }
    } else {
      mostrarNotificacion(`Código ISBN no encontrado en el catálogo de biblioteca.`, 'error');
      setLibroValidado(null);
    }
  };

  // 3. Procesar Préstamo Final (Paso 3 del Registro de Préstamo)
  const handleProcesarPrestamoAdmin = (e) => {
    e.preventDefault();
    if (!estudianteValidado || !libroValidado) {
      mostrarNotificacion(`Por favor, complete los pasos de validación 1 y 2.`, 'error');
      return;
    }

    // Descontar una unidad del catálogo
    setLibros(prev => prev.map(l => {
      if (l.id === libroValidado.id) {
        return { ...l, stock: l.stock - 1 };
      }
      return l;
    }));

    // Insertar nuevo registro de préstamo
    const nuevoRegistro = {
      id: Date.now(),
      estudianteCedula: estudianteValidado.cedula,
      libroIsbn: libroValidado.isbn,
      titulo: libroValidado.titulo,
      fechaVencimiento: fechaDevolucion,
      estado: "Al día"
    };

    setPrestamos(prev => [nuevoRegistro, ...prev]);
    agregarLog(`Préstamo registrado por bibliotecario: "${libroValidado.titulo}" entregado a ${estudianteValidado.nombre}.`);
    mostrarNotificacion(`¡Registro exitoso! Préstamo procesado en 3 clics.`, 'exito');

    // Resetear formulario para siguientes flujos
    setEstudianteValidado(null);
    setLibroValidado(null);
  };

  // Agregar nuevo libro físico al catálogo
  const handleCrearLibroAdmin = (e) => {
    e.preventDefault();
    if (!nuevoLibro.titulo || !nuevoLibro.autor || !nuevoLibro.isbn) {
      mostrarNotificacion("Por favor, rellene los campos obligatorios.", "error");
      return;
    }

    const nuevo = {
      ...nuevoLibro,
      id: Date.now()
    };

    setLibros(prev => [nuevo, ...prev]);
    agregarLog(`Bibliotecario añadió un nuevo texto al catálogo: "${nuevo.titulo}" (${nuevo.stock} unidades).`);
