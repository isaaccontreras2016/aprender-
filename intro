                </div>
                <div className="bg-slate-50 p-3 rounded-xl border border-slate-200/50">
                  <h5 className="text-[9px] font-extrabold uppercase text-slate-400">Edición</h5>
                  <p className="text-xs font-bold text-slate-800 mt-0.5">{libroDetalle.edicion}</p>
                </div>
                <div className="bg-slate-50 p-3 rounded-xl border border-slate-200/50">
                  <h5 className="text-[9px] font-extrabold uppercase text-slate-400">Ubicación Física</h5>
                  <p className="text-xs font-semibold text-emerald-700 mt-0.5">{libroDetalle.ubicación}</p>
                </div>
                <div className="bg-slate-50 p-3 rounded-xl border border-slate-200/50">
                  <h5 className="text-[9px] font-extrabold uppercase text-slate-400">Ejemplares en Stock</h5>
                  <p className="text-xs font-black text-slate-800 mt-0.5">{libroDetalle.stock} copias físicas</p>
                </div>
              </div>
            </div>

            {/* Acciones */}
            <div className="p-4 bg-slate-50 border-t border-slate-100 flex justify-end gap-2">
              <button
                type="button"
                onClick={() => setLibroDetalle(null)}
                className="px-4 py-2 text-xs font-bold text-slate-600 hover:text-slate-800 transition-colors uppercase tracking-wider"
              >
                Cerrar Ventana
              </button>
              <button
                type="button"
                onClick={() => {
                  solicitarPrestamoEstudiante(libroDetalle);
                  setLibroDetalle(null);
                }}
                disabled={libroDetalle.stock <= 0}
                className={`px-5 py-2 text-xs font-black rounded-xl transition-all uppercase tracking-wider ${
                  libroDetalle.stock > 0
                    ? 'bg-emerald-600 hover:bg-emerald-700 text-white shadow'
                    : 'bg-slate-200 text-slate-400 cursor-not-allowed'
                }`}
              >
                Solicitar Préstamo Ahora
              </button>
            </div>

          </div>
        </div>
      )}

    </div>
  );
}
