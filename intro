  // --- Estados de Datos Centralizados ---
  const [libros, setLibros] = useState(LIBROS_INICIALES);
  const [estudiantes, setEstudiantes] = useState(ESTUDIANTES_INICIALES);
  
  // Base de datos de Préstamos unificada e interactiva
