    setNuevoLibro({
      titulo: '', autor: '', isbn: '', categoria: 'Ingeniería', stock: 1, sinopsis: '', ubicación: 'Estante A-1, Piso 2', edicion: '1ra Edición'
    });
  };

  // Agregar nuevo estudiante al padrón
  const handleCrearEstudianteAdmin = (e) => {
    e.preventDefault();
    if (!nuevoEstudiante.cedula || !nuevoEstudiante.nombre) {
      mostrarNotificacion("Complete cédula y nombre del estudiante.", "error");
      return;
    }

    if (estudiantes.some(est => est.cedula === nuevoEstudiante.cedula)) {
      mostrarNotificacion("Este número de cédula ya se encuentra registrado.", "error");
      return;
    }

    setEstudiantes(prev => [...prev, nuevoEstudiante]);
    agregarLog(`Se registró nueva matrícula de biblioteca para: ${nuevoEstudiante.nombre}`);
    mostrarNotificacion(`Estudiante ${nuevoEstudiante.nombre} agregado con éxito.`, 'exito');

    setNuevoEstudiante({
      cedula: '', nombre: '', carrera: 'Ingeniería de Software', estado: 'Activo'
    });
  };

  // Editar stock de forma rápida
  const modificarStockDirecto = (id, nuevoStock) => {
    const valorNum = Math.max(0, parseInt(nuevoStock) || 0);
    setLibros(prev => prev.map(l => {
      if (l.id === id) {
        agregarLog(`Bibliotecario editó directamente el stock de "${l.titulo}" a ${valorNum} unidades.`);
        return { ...l, stock: valorNum };
      }
      return l;
    }));
  };

  // Cancelar un préstamo desde el módulo administrativo
  const cancelarPrestamoAdmin = (id, titulo, estudianteNombre) => {
    setPrestamos(prev => prev.filter(p => p.id !== id));
    setLibros(prev => prev.map(l => {
      if (l.titulo === titulo) {
        return { ...l, stock: l.stock + 1 };
      }
      return l;
    }));
    mostrarNotificacion(`Préstamo devuelto/cancelado para ${estudianteNombre}.`, 'info');
    agregarLog(`Bibliotecario cerró el préstamo del libro "${titulo}" de ${estudianteNombre}.`);
  };

  return (
    <div className="min-h-screen bg-slate-50 font-sans text-slate-800 flex flex-col selection:bg-emerald-200 selection:text-emerald-950">
      
      {/* --- BANNER DE NOTIFICACIÓN FLOTANTE --- */}
      {notificacion && (
        <div className="fixed top-5 right-5 z-50 animate-bounce shadow-2xl max-w-sm rounded-2xl p-4 flex items-start gap-3 transition-all duration-300 border bg-white">
          {notificacion.tipo === 'exito' && (
            <div className="bg-emerald-100 text-emerald-600 p-2.5 rounded-xl">
              <svg xmlns="http://www.w3.org/2000/svg" className="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
          )}
          {notificacion.tipo === 'info' && (
            <div className="bg-blue-100 text-blue-600 p-2.5 rounded-xl">
              <svg xmlns="http://www.w3.org/2000/svg" className="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z" />
              </svg>
            </div>
          )}
          {notificacion.tipo === 'error' && (
            <div className="bg-red-100 text-red-600 p-2.5 rounded-xl">
              <svg xmlns="http://www.w3.org/2000/svg" className="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
              </svg>
            </div>
          )}
          <div>
            <p className="font-extrabold text-xs text-slate-900 uppercase tracking-wide">Notificación de Biblioteca</p>
            <p className="text-xs text-slate-600 mt-1">{notificacion.mensaje}</p>
          </div>
        </div>
      )}

      {/* --- CABECERA PRINCIPAL (Estilo Institucional UNEMI) --- */}
      <header className="bg-gradient-to-r from-blue-900 to-emerald-800 text-white shadow-lg sticky top-0 z-40">
        <div className="max-w-7xl mx-auto px-4 py-3.5 flex flex-col sm:flex-row justify-between items-center gap-4">
          
          {/* Isologo UNEMI y Título del Sistema */}
          <div className="flex items-center gap-3">
            <div className="bg-white p-2 rounded-xl shadow-inner flex items-center justify-center">
              <svg width="38" height="38" viewBox="0 0 100 100" fill="none" xmlns="http://www.w3.org/2000/svg">
                <rect width="100" height="100" rx="16" fill="#0A3054"/>
                <path d="M25 30H75V40H25V30Z" fill="#10B981"/>
                <path d="M25 45H75V55H25V45Z" fill="#FFFFFF"/>
                <path d="M25 60H55V70H25V60Z" fill="#10B981"/>
                <circle cx="68" cy="65" r="5" fill="#FFFFFF"/>
              </svg>
            </div>
            <div>
              <div className="flex items-center gap-2">
                <span className="bg-emerald-500 text-[9px] font-black text-white px-1.5 py-0.5 rounded tracking-wider uppercase">UNEMI</span>
                <span className="text-xs text-emerald-200 font-medium">Universidad Estatal de Milagro</span>
              </div>
              <h1 className="text-lg md:text-xl font-black tracking-tight uppercase">Sistema Web de Biblioteca</h1>
            </div>
          </div>

          {/* Menú Superior Interactivo de Roles */}
          <div className="flex flex-wrap items-center gap-4">
            
            {/* Switcheador de Rol de Usuario */}
            <div className="bg-slate-950/40 p-1 rounded-xl flex items-center border border-white/10 shadow-inner">
              <button
                onClick={() => { setRolActivo('estudiante'); mostrarNotificacion("Acceso: Vista de Estudiante", "info"); }}
                className={`px-3 py-1.5 rounded-lg text-xs font-bold transition-all flex items-center gap-1.5 ${
                  rolActivo === 'estudiante' ? 'bg-emerald-600 text-white shadow-md' : 'text-slate-300 hover:text-white'
                }`}
              >
                <svg xmlns="http://www.w3.org/2000/svg" className="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                  <path strokeLinecap="round" strokeLinejoin="round" strokeWidth={2} d="M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253" />
                </svg>
                Vista Estudiante
              </button>
              <button
