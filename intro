      estudianteCedula: "0987654321", // María Castro Santos
      libroIsbn: "978-84-481-4644-3", // Sistemas de Bases de Datos
      titulo: "Sistemas de Bases de Datos",
      fechaVencimiento: "2026-07-02",
      estado: "Al día"
    }
  ]);

  // --- Logs de Auditoría del Bibliotecario ---
  const [logs, setLogs] = useState([
    { hora: "12:30", accion: "Bibliotecario modificó el stock del libro 'Sistemas de Bases de Datos' de 1 a 0 unidades." },
    { hora: "11:15", accion: "Estudiante María Castro Santos solicitó préstamo de 'Sistemas de Bases de Datos'." },
    { hora: "08:45", accion: "Se actualizó la base de datos de matrículas estudiantiles del período académico vigente." }
  ]);

  // --- Estados de Navegación y Roles ---
  const [rolActivo, setRolActivo] = useState('estudiante'); // 'estudiante' o 'bibliotecario'
  const [subModuloAdmin, setSubModuloAdmin] = useState('prestamos'); // 'prestamos', 'catalogo', 'usuarios'
  const [notificacion, setNotificacion] = useState(null);

  // --- Estados del Buscador de la Vista de Estudiante ---
  const [busqueda, setBusqueda] = useState('');
  const [busquedaAplicada, setBusquedaAplicada] = useState('');
